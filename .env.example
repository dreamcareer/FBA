# ── Supabase ──────────────────────────────────────────────
# Supabase > Settings > Database > Connection string (Transaction mode)
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-ap-northeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Supabase > Settings > Database > Connection string (Session mode / Direct)
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-ap-northeast-1.pooler.supabase.com:5432/postgres"

# Supabase > Settings > API > Project URL / anon key
NEXT_PUBLIC_SUPABASE_URL="https://[project-ref].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."

# Supabase > Settings > API > service_role key (サーバーサイドのみ)
SUPABASE_SERVICE_ROLE_KEY="eyJ..."

# ── Logiless ───────────────────────────────────────────────
# Logiless > アカウント設定 > APIトークン から取得
LOGILESS_API_TOKEN="your_logiless_api_token"
LOGILESS_MERCHANT_ID="1084"
LOGILESS_BASE_URL="https://app2.logiless.com/api/v1"

# ── Amazon SP-API（Phase 2）──────────────────────────────
SP_API_CLIENT_ID=""
SP_API_CLIENT_SECRET=""
SP_API_REFRESH_TOKEN=""
SP_API_MARKETPLACE_ID="A1VC38T7YXB528"  # JP marketplace

# ── 通知 ──────────────────────────────────────────────────
DISCORD_WEBHOOK_URL="https://discord.com/api/webhooks/..."
CHATWORK_API_TOKEN="your_chatwork_token"
CHATWORK_ROOM_ID="335784045"

# ── アプリ設定 ─────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
CRON_SECRET="your_random_secret_for_cron_jobs"
